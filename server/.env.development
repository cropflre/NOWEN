# 后端开发环境配置

# 服务端口
PORT=3001

# Node 环境
NODE_ENV=development

# 前端地址（CORS 白名单）
FRONTEND_URL=http://localhost:5173

# ========== AI 智能分类配置（可选） ==========
# 支持 openai | gemini | custom (兼容 OpenAI 协议的本地模型如 Ollama)
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxx
# AI_MODEL=gpt-4o-mini

# Gemini 示例:
# AI_PROVIDER=gemini
# AI_API_KEY=xxx
# AI_MODEL=gemini-2.0-flash

# Ollama 本地模型示例:
# AI_PROVIDER=custom
# AI_API_BASE=http://localhost:11434/v1
# AI_MODEL=qwen2.5:7b
